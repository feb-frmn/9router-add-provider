# B.AI (chat.b.ai) API Key — 9router provider config
# Each B.AI key gives ~1M tokens/day free (GLM-5.2 model).
# Premium models (gpt-*, kimi-*) need deposit — script auto-skips them.
#
# Usage: bash add-provider.sh --config examples/bai.env
#   or:  bash add-bai.sh --key "sk-or-v1-xxx"

NAME="bai-account"
PREFIX="bai"
URL="https://api.b.ai/v1"
API_KEY="sk-or-v1-your-key-here"
