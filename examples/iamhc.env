# iamhc.cn — Chinese AI API aggregator
# Models: Kimi-K2.6, DeepSeek-V4-Pro, GLM series, Qwen, MiniMax
# Free tier with limited quota
# Docs: https://api.iamhc.cn

NAME="iamhc"
PREFIX="iamhc"
URL="https://api.iamhc.cn/v1"
KEY="sk-your-iamhc-key"

# Available models (use as iamhc/<model>):
# iamhc/Kimi-K2.6               — Moonshot Kimi K2.6
# iamhc/DeepSeek-V4-Pro          — DeepSeek V4 Pro
# iamhc/Qwen3.5-397B-A17B        — Qwen 3.5 397B
# iamhc/Qwen3-Coder-Next-FP8     — Qwen 3 Coder
# iamhc/glm-4.7                  — GLM 4.7
# iamhc/glm-5.2                  — GLM 5.2
# iamhc/kat-coder-pro-v2          — Kat Coder Pro
# iamhc/MiniMax-M3               — MiniMax M3
# iamhc/auto                     — Auto-select best model
