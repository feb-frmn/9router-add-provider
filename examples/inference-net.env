# Inference.net — Decentralized GPU inference
# Get API key: https://inference.net → Dashboard → API Keys
# Docs: https://docs.inference.net
# Pricing: pay-per-token

NAME="inference"
PREFIX="inf"
URL="https://api.inference.net/v1"
KEY="sk-your-inference-net-key"

# ⚠️  Inference.net uses org/model/quant format, NOT short names!
#
# Available models (use as inf/<model>):
#
# DeepSeek:
#   inf/deepseek/deepseek-v3/fp-8
#   inf/deepseek/deepseek-v3-0324/fp-8
#   inf/deepseek/deepseek-r1/fp-8
#   inf/deepseek/deepseek-r1-0528/fp-8
#   inf/deepseek/r1-distill-llama-70b/fp-8
#
# Llama:
#   inf/meta-llama/llama-3.3-70b-instruct/fp-8
#   inf/meta-llama/llama-3.1-70b-instruct/fp-16
#   inf/meta-llama/llama-3.2-11b-instruct/fp-16
#   inf/meta-llama/llama-3.2-3b-instruct/fp-16
#   inf/meta-llama/llama-3.2-1b-instruct/fp-16
#   inf/meta-llama/llama-3.1-8b-instruct/fp-16
#
# Qwen:
#   inf/qwen/qwq-32b/fp-8
#   inf/qwen/qwen2.5-7b-instruct/bf-16
#   inf/qwen/qwen3-30b-a3b/fp8
#
# Google:
#   inf/google/gemma-3-27b-instruct/bf-16
#
# Mistral:
#   inf/mistralai/mistral-nemo-12b-instruct/fp-8
#
# OpenAI-compatible (via inference.net):
#   inf/openai/gpt-oss-120b
#   inf/openai/gpt-oss-20b
#
# Run `bash add-provider.sh --config examples/inference-net.env`
# Then: curl .../v1/models to see latest model list
