# Inference.net — GPU inference platform
# Models: GLM-5.2, Claude Opus 4.6-4.8, Claude Sonnet 4.6, Nemotron 3 Super, GPT-4.1 series
# Pricing: pay-per-token, no free tier
# Docs: https://docs.inference.net

NAME="inference"
PREFIX="inf"
URL="https://api.inference.net/v1"
KEY="sk-your-inference-net-key"

# Available models (use as inf/<model>):
# inf/glm-5.2                    — GLM 5.2 ($1.30/$4.40 per 1M tokens)
# inf/claude-opus-4-6            — Claude Opus 4.6
# inf/claude-opus-4-7            — Claude Opus 4.7
# inf/claude-opus-4-8            — Claude Opus 4.8
# inf/claude-sonnet-4-6          — Claude Sonnet 4.6
# inf/claude-haiku-4-5           — Claude Haiku 4.5
# inf/gpt-4.1                    — GPT-4.1
# inf/gpt-4.1-mini               — GPT-4.1 Mini
# inf/gpt-4.1-nano               — GPT-4.1 Nano
# inf/gpt-4o                     — GPT-4o
# inf/gpt-4o-mini                — GPT-4o Mini
# inf/gpt-5-mini                 — GPT-5 Mini
# inf/gpt-5-nano                 — GPT-5 Nano
# inf/gpt-5.4                    — GPT-5.4
# inf/gpt-5.5                    — GPT-5.5
# inf/nemotron-3-super           — Nemotron 3 Super 120B
# inf/gemini-2.5-flash           — Gemini 2.5 Flash
# inf/gemini-2.5-pro             — Gemini 2.5 Pro
# inf/gemini-3.5-flash           — Gemini 3.5 Flash
