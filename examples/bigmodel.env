# BigModel (智谱 Zhipu) — Chinese AI platform
# Models: GLM-4.5 through GLM-5.2, GLM-5-Turbo
# Free tier: limited quota on signup
# Docs: https://open.bigmodel.cn

NAME="bigmodel"
PREFIX="bg"
URL="https://open.bigmodel.cn/api/paas/v4"
KEY="your-bigmodel-api-key"

# Available models (use as bg/<model>):
# bg/glm-4.5                     — GLM 4.5
# bg/glm-4.6                     — GLM 4.6
# bg/glm-4.7                     — GLM 4.7
# bg/glm-5                       — GLM 5
# bg/glm-5.1                     — GLM 5.1
# bg/glm-5.2                     — GLM 5.2
# bg/glm-5-turbo                 — GLM 5 Turbo (fast)
