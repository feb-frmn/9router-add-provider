# Template for adding your own custom provider
# Copy this file, fill in the values, then run:
#   bash add-provider.sh --config examples/my-provider.env

NAME="my-provider"           # Display name in dashboard
PREFIX="mp"                  # Model prefix (use as mp/model-name)
URL="https://api.example.com/v1"   # Base URL (NO /chat/completions suffix!)
KEY="sk-your-api-key"        # Your API key

# Optional overrides (uncomment if needed):
# API_TYPE="chat"            # "chat" (default) or "responses"
# TYPE="openai-compatible"   # "openai-compatible" (default), "anthropic-compatible", "custom-embedding"
# HOST="localhost:20128"     # 9router host:port
