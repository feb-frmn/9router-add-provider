# LLM7 — Free LLM API gateway
# Models: GPT-OSS-120B, GLM-4.6V-Flash, codestral
# Free tier: 2 RPS / 20 RPM / 100 RPH
# URL: https://llm7.io

NAME="llm7"
PREFIX="llm7"
URL="https://api.llm7.io/v1"
KEY="sk-your-llm7-key"

# Available models (use as llm7/<model>):
# llm7/gpt-oss:20b               — GPT-OSS 20B
# llm7/GLM-4.6V-Flash            — GLM 4.6V Flash (vision)
# llm7/codestral-latest           — Codestral (code)
